<Window x:Class="viragShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:viragShop"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <ResourceDictionary Source="Resources/Buttons.xaml" />
    </Window.Resources>

    <DockPanel Background="DarkSeaGreen">

        <StackPanel DockPanel.Dock="Top" Background="ForestGreen" Height="60">
            <TextBlock Text="VirágShop Adminisztráció"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 5"/>
        </StackPanel>

        <WrapPanel DockPanel.Dock="Top"
                   Orientation="Horizontal"
                   HorizontalAlignment="Center"
                   Margin="0 0"
                   Background="ForestGreen" 
                   Width="800">

            <Button Content="Virágok"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Click="ViragMenu_Click"
                    Style="{StaticResource buttons}"/>

            <Button Content="Vásárlók"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Click="VasarloMenu_Click"
                    Style="{StaticResource buttons}"/>

            <Button Content="Munkások"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Click="MunkasMenu_Click"
                    Style="{StaticResource buttons}"/>

            <Button Content="Szerepkörök"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Click="SzerepkorMenu_Click"
                    Style="{StaticResource buttons}"/>

            <Button Content="Kilépés"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Background="Red"
                    Foreground="White"
                    Click="KilepesMenu_Click"
                    Style="{StaticResource buttons}"/>

        </WrapPanel>

        <StackPanel x:Name="feladatPanel"
                    Margin="10"/>
    </DockPanel>
</Window>
