<UserControl x:Class="viragShop.UserControls.UserControlViragVasarlas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:viragShop.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer>
        <ItemsControl x:Name="viragListaControl">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="MistyRose"
                            CornerRadius="10"
                            Padding="15"
                            Margin="10"
                            Width="250">

                        <StackPanel>

                            <TextBlock Text="{Binding Nev}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"/>

                            <TextBlock Text="{Binding Leiras}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,5"/>

                            <TextBlock Text="Ár:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Ar}" Margin="0,0,0,5"/>

                            <TextBlock Text="Mennyiség:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Mennyiseg}" Margin="0,0,0,10"/>

                            <Button Content="Vásárlás"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Padding="5"
                                    Click="Vasarlas_Click"/>
                        </StackPanel>

                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
